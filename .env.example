# Docker Compose project name. Keep this stable so container names are predictable.
COMPOSE_PROJECT_NAME=carbontrack

# MySQL database name and credentials used by backend and db service.
DB_NAME=carbontrack_db
DB_USER=carbontrack_user
DB_PASSWORD=carbontrack_pwd
DB_ROOT_PASSWORD=carbontrack_root

# Backend JWT signing secret. Replace before production use.
JWT_SECRET=change_me_to_a_long_random_string

# Host port mappings.
FRONTEND_PORT=18411
BACKEND_PORT=19411
DB_PORT=3306

# Docker internal database host and port.
MYSQL_HOST=db
MYSQL_PORT=3306

# Keep false when database/init.sql creates tables.
TYPEORM_SYNC=false

# Shared logging level.
LOG_LEVEL=info

